{
  "version": 2,
  "crons": [
    { "path": "/api/cron/sync-orders",        "schedule": "0 2 * * *" },
    { "path": "/api/cron/sync-products",      "schedule": "30 2 * * *" },
    { "path": "/api/cron/sync-advertising",   "schedule": "0 3 * * *" },
    { "path": "/api/cron/sync-subscriptions", "schedule": "30 3 * * *" }
  ],
  "functions": {
    "api/sales.js":                    { "maxDuration": 30 },
    "api/products.js":                 { "maxDuration": 30 },
    "api/advertising.js":              { "maxDuration": 30 },
    "api/subscriptions.js":            { "maxDuration": 30 },
    "api/cron/sync-orders.js":         { "maxDuration": 300 },
    "api/cron/sync-products.js":       { "maxDuration": 300 },
    "api/cron/sync-advertising.js":    { "maxDuration": 300 },
    "api/cron/sync-subscriptions.js":  { "maxDuration": 300 }
  },
  "routes": [
    {
      "src": "/(.+)",
      "headers": {
        "Access-Control-Allow-Origin":  "*",
        "Access-Control-Allow-Methods": "GET, OPTIONS",
        "Access-Control-Allow-Headers": "Content-Type"
      },
      "continue": true
    },
    { "src": "/reports/dazzle-dry", "dest": "/reports/dazzle-dry/index.html" },
    { "src": "/",                   "dest": "/index.html" }
  ]
}
